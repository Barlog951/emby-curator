# Emby dashboards configuration
#
# Setup: copy this file to dashboards/.env and fill in real values,
# OR export the same variables in your environment before launching marimo.
# Environment variables take precedence over this file.
#
# EMBY_HOST      — base URL of your Emby server (no trailing slash)
# EMBY_API_KEY   — Emby Dashboard > Advanced > API Keys
# TMDB_TOKEN     — TMDB v4 Read Access Token (https://www.themoviedb.org/settings/api)
#                  Only needed by emby_missing.py.
EMBY_HOST=https://your-emby-server.example.com
EMBY_API_KEY=your-emby-api-key
TMDB_TOKEN=your-tmdb-v4-read-access-token
